# MongoDB Connection String (Get this from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/grievancesystem

# Frontend URL (The URL of your Vercel app)
FRONTEND_URL=https://your-app-name.vercel.app

# Node Environment
NODE_ENV=production

# Server Port (Render will provide this automatically)
PORT=5000
